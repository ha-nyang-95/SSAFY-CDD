# ======================================================= 
# Git LFS (Large File Storage) 설정
# ======================================================= 
*.zip filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.img filter=lfs diff=lfs merge=lfs -text

# =======================================================
# 줄 바꿈 (Line Ending) 설정 => 리눅스,,파일 적용
# =======================================================
* text=auto
*.conf eol=lf
*.nmconnection eol=lf
*.sh eol=lf
*.py text eol=lf
*.txt text eol=lf